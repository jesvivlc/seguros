# =============================================================================
# Variables de entorno — CRM Correduría de Seguros
# Rellena estos valores con los de TU proyecto de Supabase (Settings > API).
# =============================================================================

# URL del proyecto (Settings > API > Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co

# Clave pública anon (Settings > API > Project API keys > anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY=TU_ANON_KEY

# Clave service_role (Settings > API > Project API keys > service_role) — SECRETA.
# Necesaria para: crear la usuaria, ejecutar el seed y el cron. NUNCA se expone al cliente.
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY

# Secreto para proteger el endpoint del cron /api/cron/renovaciones.
# Genera uno con: openssl rand -hex 32
CRON_SECRET=cambia_esto_por_un_secreto_largo

# Datos de la usuaria inicial (usados por scripts/create-user.mjs)
SEED_USER_EMAIL=asesora@example.com
SEED_USER_PASSWORD=CambiaEstaClave123!
